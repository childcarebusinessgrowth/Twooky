# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
# Use ONE of these publishable keys (prefer the publishable default key if you have it)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (required for server-only data: admin tools, homepage featured listings, etc.)
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps / Places / Geocoding
# Server-side geocoding can use either key; prefer the server key.
GOOGLE_MAPS_API_KEY=
# Client-side Maps requires the public key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Site
# Used to generate absolute metadata URLs (OpenGraph, etc.) in production.
NEXT_PUBLIC_SITE_URL=

# Resend (transactional email — provider inquiry notifications, etc.)
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# From address (must match a verified domain in Resend, OR use Resend's test sender).
# Production: verify twooky.com at https://resend.com/domains then e.g. Twooky <notifications@twooky.com>
# Local/dev until DNS is verified: use Resend's built-in sender (no domain setup):
# RESEND_FROM=onboarding@resend.dev
# If RESEND_FROM is omitted, code defaults to Twooky <onboarding@resend.dev>
# RESEND_FROM=Twooky <notifications@twooky.com>

