## Supabase
# Required for browser/server clients.
NEXT_PUBLIC_SUPABASE_URL=

# Preferred public key used by app clients.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional fallback public key if PUBLISHABLE_DEFAULT is not set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for admin actions/routes (never expose client-side).
SUPABASE_SERVICE_ROLE_KEY=

## Google Maps / Geocoding
# Server key used by API routes for geocoding and place lookup.
GOOGLE_MAPS_API_KEY=

# Public key used by client map rendering components.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
