# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
# Use ONE of these publishable keys (prefer the publishable default key if you have it)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (required for server-only data: admin tools, homepage featured listings, etc.)
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps / Places / Geocoding
# Server-side geocoding can use either key; prefer the server key.
GOOGLE_MAPS_API_KEY=
# Client-side Maps requires the public key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Cron route auth secret (Vercel cron sends Authorization: Bearer <CRON_SECRET>).
CRON_SECRET=

# Site
# Used to generate absolute metadata URLs (OpenGraph, etc.) in production.
# Root apex domain for provider microsites and host-based rewrites in proxy.ts.
# Example: earlylearningdirectory.com enables provider microsites like
# https://my-nursery.earlylearningdirectory.com
NEXT_PUBLIC_SITE_ROOT_DOMAIN=
# Password reset emails use redirect_to = ${NEXT_PUBLIC_SITE_URL}/update-password unless overridden below.
# Required: add that exact URL in Supabase → Authentication → URL configuration → Redirect URLs
# (e.g. https://twooky.vercel.app/update-password). If missing, Supabase falls back to Site URL (/) and
# the app still forwards #access_token recovery hashes to /update-password via AuthRecoveryRedirect).
NEXT_PUBLIC_SITE_URL=
# Optional explicit password reset redirect when it must differ from the public site URL.
# PASSWORD_RESET_REDIRECT_URL=https://your-domain.com/update-password
PASSWORD_RESET_REDIRECT_URL=

# Feature flags / diagnostics
# When unset the provider website builder defaults to enabled.
# NEXT_PUBLIC_PROVIDER_WEBSITE_BUILDER_ENABLED=true
NEXT_PUBLIC_PROVIDER_WEBSITE_BUILDER_ENABLED=
# Enable structured server perf logs with value "1".
APP_PERF_LOGS=
# Enable Next bundle analysis locally with value "true".
ANALYZE=

# Resend (transactional email — provider inquiries, password reset, etc.)
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# From address (must match a verified domain in Resend, OR use Resend's test sender).
# Production: verify twooky.com at https://resend.com/domains then e.g. Twooky <notifications@twooky.com>
# Local/dev until DNS is verified: use Resend's built-in sender (no domain setup):
# RESEND_FROM=onboarding@resend.dev
# If RESEND_FROM is omitted, code defaults to Twooky <onboarding@resend.dev>
# RESEND_FROM=Twooky <notifications@twooky.com>

# Stripe billing (provider subscriptions)
# Publishable key is used by the pricing page / provider dashboard checkout buttons.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key is used by server routes and webhook verification.
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Optional explicit return path after leaving the Stripe billing portal.
# Defaults to ${NEXT_PUBLIC_SITE_URL}/dashboard/provider/subscription when omitted.
STRIPE_BILLING_PORTAL_RETURN_URL=
# Stripe recurring price IDs for paid provider plans.
STRIPE_PRICE_GROW_MONTHLY=
STRIPE_PRICE_GROW_YEARLY=
STRIPE_PRICE_THRIVE_MONTHLY=
STRIPE_PRICE_THRIVE_YEARLY=

